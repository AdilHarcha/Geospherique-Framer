{
  "outputDirectory": "public",
  "routes": [
    {
      "src": "/geospherique-listes/partager-un-savoir/([^/]+)$",
      "dest": "/api/post?type=formation&slug=$1"
    },
    {
      "src": "/partager-un-savoir/geospherique-partages/([^/]+)$",
      "dest": "/api/post?type=atelier&slug=$1"
    },
    {
      "src": "/partager-un-savoir/geospherique-tools/([^/]+)$",
      "dest": "/api/post?type=outil&slug=$1"
    },
    {
      "src": "/les-travers%C3%A9es-de-geospherique/([^/]+)$",
      "dest": "/api/post?type=travers%C3%A9e&slug=$1"
    },
    { "handle": "filesystem" }
  ]
}
